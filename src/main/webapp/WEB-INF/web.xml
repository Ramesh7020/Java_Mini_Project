<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <servlet>
        <servlet-name>AddReservation</servlet-name>
        <servlet-class>com.servlet.AddReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddReservation</servlet-name>
        <url-pattern>/AddReservationServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateReservation</servlet-name>
        <servlet-class>com.servlet.UpdateReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateReservation</servlet-name>
        <url-pattern>/UpdateReservationServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteReservation</servlet-name>
        <servlet-class>com.servlet.DeleteReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteReservation</servlet-name>
        <url-pattern>/DeleteReservationServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DisplayReservations</servlet-name>
        <servlet-class>com.servlet.DisplayReservationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DisplayReservations</servlet-name>
        <url-pattern>/DisplayReservationsServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReportCriteria</servlet-name>
        <servlet-class>com.servlet.ReportCriteriaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportCriteria</servlet-name>
        <url-pattern>/ReportCriteriaServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Report</servlet-name>
        <servlet-class>com.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Report</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>